            "properties": {
              "text": "{\n  \"style_mode\": \"raw_photoreal_high_fidelity\",\n  \"look\": \"social media realism, smartphone aesthetic, UGC B-roll for Meta ads\",\n  \"aspect_ratio\": \"9:16 vertical\",\n  \"broll_id\": 2,\n  \"broll_title\": \"RAZOR TOSS — END FRAME\",\n  \"used_in\": \"Video Plan Scene 2 — THE EVIDENCE (Shot B)\",\n  \"delta_from\": \"broll-02-image-start.json\",\n  \"requires\": [],\n\n  \"camera\": {\n    \"change_from_start\": \"same overhead-ish handheld angle on the counter. Hand is completely gone from frame\"\n  },\n\n  \"scene\": {\n    \"subject\": {\n      \"change_from_start\": \"hand is gone. The cheap disposable razor lies on the counter where it landed — slightly crooked, blade head facing away. It looks small, cheap, and forgotten. The counter space around it is more visible now without the hand — just this sad little razor sitting by itself on the counter like an afterthought. The emptiness of the frame around the abandoned razor makes it look even more disposable\"\n    }\n  },\n\n  \"narrative_prompt\": \"Same casual overhead smartphone shot of the bathroom counter, but the hand is completely gone. The cheap purple disposable razor lies alone on the counter — slightly crooked where it landed, blade head angled away. The counter space around it is visible now, making the razor look small, cheap, and abandoned. No hand, no person — just a sad disposable razor sitting by itself. Same warm light, same smartphone quality, same off-center framing. The visual says 'I'm done with you.'\"\n}\n",
