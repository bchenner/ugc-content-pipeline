            "title": "Prompt 7",
            "properties": {
              "text": "{\n  \"style_mode\": \"raw_photoreal_high_fidelity\",\n  \"look\": \"social media realism, smartphone aesthetic, UGC B-roll for Meta ads\",\n  \"aspect_ratio\": \"9:16 vertical\",\n  \"broll_id\": 3,\n  \"broll_title\": \"SHAVING FRUSTRATION\",\n  \"used_in\": \"Video Plan Scene 2 — THE EVIDENCE (Shot C)\",\n  \"duration\": \"4s\",\n  \"requires\": [],\n\n  \"camera\": {\n    \"vantage\": \"handheld, looking down at her own leg — the POV of someone filming themselves shaving, sitting on the edge of a bathtub\",\n    \"framing\": \"medium shot of lower leg, shin visible, hand holding a disposable razor mid-stroke on the leg. Framing is casual — you can see the bathtub edge, maybe some shower products in the background blurred out\",\n    \"lens_behavior\": \"smartphone camera, ~26mm, auto-focus on the leg/razor area\",\n    \"sensor_quality\": \"digital grain, smartphone in bathroom light\",\n    \"shake\": \"noticeable handheld shake — she's literally filming with one hand while doing something with the other\"\n  },\n\n  \"scene\": {\n    \"environment\": {\n      \"setting\": \"bathroom — sitting on the edge of a bathtub or shower ledge. Casual, real bathroom environment. Some shaving cream or body wash visible nearby\",\n      \"lighting\": {\n        \"key_light\": \"overhead bathroom light, warm-ish, standard residential fixture\",\n        \"fill\": \"ambient bounce from bathroom walls and fixtures\",\n        \"quality\": \"standard indoor bathroom lighting, nothing styled\"\n      }\n    },\n\n    \"subject\": {\n      \"obj_001\": {\n        \"type\": \"lower leg being groomed\",\n        \"description\": \"woman's lower leg, shin area. Wet skin with some shaving cream or soap lather partially visible. Warm medium skin tone. She's mid-grooming routine — the everyday moment\",\n        \"texture\": \"wet skin with water droplets, some soap lather, natural\"\n      },\n      \"obj_002\": {\n        \"type\": \"disposable razor in hand\",\n        \"description\": \"same generic cheap disposable razor from broll-02 (light purple handle, 3-blade). Held in her right hand mid-stroke on the leg — the routine act that causes the bumps. Her grip is casual, practiced — she's done this a thousand times\",\n        \"positioning\": \"razor is on the leg, mid-stroke, angled for a standard grooming pass\"\n      }\n    }\n  },\n\n  \"aesthetic_controls\": {\n    \"render_intent\": \"UGC B-roll — the everyday grooming moment that causes all the problems. Shot like someone who propped their phone up or is filming one-handed to document their routine. Casual, relatable, slightly annoying energy\",\n    \"degradation\": {\n      \"grain\": \"noticeable smartphone grain\",\n      \"dynamic_range\": \"limited — bathroom fluorescent or overhead light\",\n      \"color_science\": \"warm, slightly flat — typical bathroom selfie quality\"\n    }\n  },\n\n  \"negative_prompt\": {\n    \"forbidden_elements\": [\n      \"face visible\", \"blood or injury\", \"cuts on skin\",\n      \"clinical setting\", \"professional photography setup\",\n      \"perfect composition\", \"beauty lighting\"\n    ],\n    \"forbidden_style\": [\n      \"anime\", \"CGI\", \"3D render\", \"illustration\",\n      \"stock photo\", \"commercial photography\",\n      \"studio lighting\", \"glamour shot\"\n    ]\n  },\n\n  \"narrative_prompt\": \"A casual smartphone shot looking down at a woman's lower leg as she uses a cheap disposable razor — the everyday grooming routine that causes razor bumps. She's sitting on the edge of a bathtub, wet skin with some soap lather, the generic purple-handled disposable razor mid-stroke on her shin. The shot is filmed like a POV selfie — one-handed, slightly shaky, handheld smartphone quality. You can see the bathtub edge and some blurred shower products in the background. Standard overhead bathroom lighting, nothing styled. Digital grain, slightly flat color. 9:16 vertical. The mundane moment everyone recognizes — the routine that never quite works out.\"\n}",
