            "title": "Prompt 4",
            "properties": {
              "text": "{\n  \"style_mode\": \"raw_photoreal_high_fidelity\",\n  \"look\": \"social media realism, smartphone aesthetic, UGC B-roll for Meta ads\",\n  \"aspect_ratio\": \"9:16 vertical\",\n  \"broll_id\": 2,\n  \"broll_title\": \"RAZOR TOSS\",\n  \"used_in\": \"Video Plan Scene 2 — THE EVIDENCE (Shot B)\",\n  \"duration\": \"4s\",\n  \"requires\": [],\n\n  \"camera\": {\n    \"vantage\": \"handheld, looking down at bathroom counter — casual overhead-ish angle, not perfectly composed\",\n    \"framing\": \"counter surface with razor visible, hand entering from top of frame. Framing is slightly off-center, not styled\",\n    \"lens_behavior\": \"smartphone camera, ~26mm, auto-focus on counter\",\n    \"sensor_quality\": \"digital grain, smartphone in indoor light\",\n    \"shake\": \"slight handheld movement — she's filming one-handed\"\n  },\n\n  \"scene\": {\n    \"environment\": {\n      \"setting\": \"bathroom counter — same elevated bathroom as demo scenes but captured casually. Counter surface visible with some everyday items\",\n      \"lighting\": {\n        \"key_light\": \"natural morning light from window, warm\",\n        \"fill\": \"ambient bathroom light\",\n        \"quality\": \"natural, uncontrolled indoor light\"\n      }\n    },\n\n    \"subject\": {\n      \"obj_001\": {\n        \"type\": \"traditional disposable razor\",\n        \"description\": \"generic women's disposable razor — plastic handle (light purple or teal), 3-blade head. Cheap, unremarkable, the kind everyone has\",\n        \"positioning\": \"mid-toss — being dropped onto the counter by a woman's hand with casual 'I'm done' energy\"\n      },\n      \"obj_002\": {\n        \"type\": \"woman's hand\",\n        \"description\": \"warm medium skin tone, natural nails, relaxed fingers releasing the razor\",\n        \"positioning\": \"entering from top of frame, mid-release\"\n      }\n    }\n  },\n\n  \"aesthetic_controls\": {\n    \"render_intent\": \"UGC B-roll — casually tossing the old razor aside. Not a dramatic gesture, just the everyday 'throwing this in the drawer' energy\",\n    \"degradation\": {\n      \"grain\": \"smartphone grain, slightly noisy\",\n      \"dynamic_range\": \"limited — smartphone\",\n      \"color_science\": \"warm, natural\"\n    }\n  },\n\n  \"negative_prompt\": {\n    \"forbidden_elements\": [\n      \"face visible\", \"premium razor brands\", \"brand logos\",\n      \"blood or injury\", \"text overlays\", \"perfect composition\"\n    ],\n    \"forbidden_style\": [\n      \"anime\", \"CGI\", \"3D render\", \"illustration\",\n      \"stock photo\", \"commercial product photography\",\n      \"studio lighting\", \"beauty photography\"\n    ]\n  },\n\n  \"narrative_prompt\": \"A casual smartphone shot looking down at a bathroom counter. A woman's hand drops a cheap disposable women's razor onto the counter — generic purple plastic handle, 3-blade head. The hand is mid-release, fingers opening with casual 'I'm done with this' energy. Not dramatic, just dismissive. Counter has some everyday bathroom items partially visible. Warm natural light from a window, slightly off-center framing, handheld smartphone quality with visible grain. 9:16 vertical. The kind of shot someone would film one-handed while venting about their old razor.\"\n}",
