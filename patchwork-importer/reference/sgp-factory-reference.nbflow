            "title": "Prompt 1",
            "properties": {
              "text": "{\n  \"style_mode\": \"raw_photoreal_high_fidelity\",\n  \"look\": \"social media realism, smartphone aesthetic, UGC B-roll for Meta ads\",\n  \"aspect_ratio\": \"9:16 vertical\",\n  \"broll_id\": 1,\n  \"broll_title\": \"RAZOR BUMPS CLOSE-UP\",\n  \"used_in\": \"Video Plan Scene 2 — THE EVIDENCE (Shot A)\",\n  \"duration\": \"4s\",\n  \"requires\": [],\n\n  \"camera\": {\n    \"vantage\": \"handheld close-up, looking down at leg or forearm — the angle you'd use filming your own skin on your phone\",\n    \"framing\": \"close-up but not macro — skin fills most of frame, you can see enough context to know it's a leg or arm. The kind of zoom you'd do on your phone camera, not a dedicated macro lens\",\n    \"lens_behavior\": \"smartphone camera, ~26mm, portrait mode blur on background\",\n    \"sensor_quality\": \"digital grain, slightly soft focus — smartphone trying to focus close-up\",\n    \"shake\": \"slight handheld movement — she's holding her phone in one hand filming her own skin\"\n  },\n\n  \"scene\": {\n    \"environment\": {\n      \"setting\": \"bathroom — you can see blurred bathroom floor tiles or bathtub edge in the background. Not styled, just where she happened to notice the bumps\",\n      \"lighting\": {\n        \"key_light\": \"overhead bathroom light, slightly warm, nothing special\",\n        \"fill\": \"ambient bathroom lighting\",\n        \"quality\": \"even indoor light, not cinematic — just a bathroom\"\n      }\n    },\n\n    \"subject\": {\n      \"obj_001\": {\n        \"type\": \"skin showing razor bumps\",\n        \"description\": \"realistic female skin on upper leg or forearm showing everyday razor bumps — small raised red bumps, the kind most women get. Not extreme, not medical. Just annoying. Warm medium skin tone\",\n        \"texture\": \"natural skin, visible pores, slight redness around bumps, natural skin sheen\"\n      }\n    }\n  },\n\n  \"aesthetic_controls\": {\n    \"render_intent\": \"UGC smartphone close-up — like she pulled out her phone to show her friend what her skin looks like after shaving. Casual, not produced\",\n    \"degradation\": {\n      \"grain\": \"noticeable smartphone grain, slightly noisy image\",\n      \"dynamic_range\": \"limited — smartphone in bathroom light\",\n      \"color_science\": \"warm, slightly yellow from overhead bathroom light\"\n    }\n  },\n\n  \"negative_prompt\": {\n    \"forbidden_elements\": [\n      \"face visible\", \"severe skin condition\", \"bleeding\",\n      \"medical photography\", \"clinical setting\", \"macro lens quality\"\n    ],\n    \"forbidden_style\": [\n      \"anime\", \"CGI\", \"3D render\", \"illustration\",\n      \"stock photo\", \"professional photography\", \"studio lighting\",\n      \"beauty photography\", \"perfect composition\"\n    ]\n  },\n\n  \"narrative_prompt\": \"A smartphone close-up of skin on a leg or forearm showing everyday razor bumps — small raised red bumps, the kind most women get after shaving. Not extreme, just annoying and relatable. Shot looks like someone filming their own skin to show a friend — handheld, slightly shaky, phone trying to focus close-up. You can see blurred bathroom tiles or bathtub edge in the background. Overhead bathroom lighting, warm and even, nothing styled. Noticeable smartphone grain. Warm medium skin tone. 9:16 vertical. UGC energy — this is a frustrated selfie of bad skin, not a dermatology photo.\"\n}",
