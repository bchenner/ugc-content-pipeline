            "title": "Prompt 2",
            "properties": {
              "text": "{\n  \"style_mode\": \"raw_photoreal_high_fidelity\",\n  \"look\": \"social media realism, smartphone aesthetic, UGC B-roll for Meta ads\",\n  \"aspect_ratio\": \"9:16 vertical\",\n  \"broll_id\": 1,\n  \"broll_title\": \"RAZOR BUMPS CLOSE-UP — END FRAME\",\n  \"used_in\": \"Video Plan Scene 2 — THE EVIDENCE (Shot A)\",\n  \"delta_from\": \"broll-01-image-start.json\",\n  \"requires\": [],\n\n  \"camera\": {\n    \"change_from_start\": \"phone has pulled back slightly to show more skin area. Same casual handheld quality, same bathroom background\"\n  },\n\n  \"scene\": {\n    \"subject\": {\n      \"change_from_start\": \"wider view now — her fingertip is pressing into the bumpy skin, making an indent. The pressed area shows how raised and irritated the bumps are compared to the finger pressing down on them. More skin visible now, showing the bumps aren't just in one spot — they're spread across a larger area of the leg or forearm. The fingertip contact makes the texture unmistakable\"\n    }\n  },\n\n  \"narrative_prompt\": \"Same smartphone shot of razor-bumped skin, but now pulled back slightly to show a wider area. Her fingertip is pressing into the bumpy skin — you can see the indent where she's pushing, making the raised irritated texture impossible to miss. The bumps spread across more visible skin now, not just one small patch. Same casual handheld quality, same bathroom background, same UGC energy. She's poking at it the way you do when you're annoyed — showing someone how bad it actually is.\"\n}\n",
              "variableName": "Prompt 2",
              "_advancedOpen": false,
              "batchMode": false,
              "templateMode": false,
