            "title": "1. Prompt: ES-2 Portrait (from scratch)",
            "properties": {
              "text": "{\n  \"subject\": {\n    \"description\": \"A Latino man in his late twenties, looking directly into the camera with a slight smolder, chin tilted down just a fraction, one eyebrow barely raised, shoulders square and broad filling the frame\",\n    \"age\": \"late 20s to early 30s\",\n    \"expression\": \"intense direct eye contact, lips slightly parted like he is about to speak, confident bordering on cocky but with warmth behind the eyes, not smiling but the corners of his mouth hint at it\"\n  },\n  \"face\": {\n    \"structure\": \"razor sharp jawline with visible jaw muscles, high prominent cheekbones that catch the light, straight nose with a subtle bridge, strong chin, symmetrical bone structure\",\n    \"eyebrows\": \"thick dark eyebrows, naturally full with a defined arch, slightly furrowed adding intensity\",\n    \"eyes\": \"vivid green eyes, bright and piercing, the kind of green that stands out against tan skin, clear and saturated, focal point of the entire image\",\n    \"skin\": \"warm golden tan, healthy sun kissed tone, not pale at all, light stubble across the jaw and upper lip, about two days of growth, adds ruggedness without looking unkempt\",\n    \"note\": \"this is a casting portrait to lock the face, render all facial features with full clarity\"\n  },\n  \"hair\": {\n    \"color\": \"dark brown, almost black\",\n    \"style\": \"medium length on top, textured and tousled like he just ran his hands through it, pieces falling naturally across the forehead, not styled with product but has natural volume and movement, shorter on the sides but blended and soft, not a sharp line up or hard fade, more like a model off duty than a fresh barbershop cut\"\n  },\n  \"clothing\": {\n    \"top\": {\n      \"type\": \"fitted athletic t shirt\",\n      \"color\": \"dark charcoal grey\",\n      \"details\": \"stretches across broad muscular shoulders and defined arms, plain fabric, no logos, no patterns\"\n    }\n  },\n  \"accessories\": {\n    \"wrist\": {\n      \"type\": \"black fitness tracker\",\n      \"details\": \"worn on left wrist, matte black band, minimal digital display\"\n    }\n  },\n  \"photography\": {\n    \"camera_style\": \"smartphone portrait mode, close and personal\",\n    \"angle\": \"eye level, straight on\",\n    \"shot_type\": \"head and shoulders, tight crop just below the collarbone\",\n    \"aspect_ratio\": \"9:16 vertical\",\n    \"texture\": \"sharp focus on face especially the eyes, soft natural light, social media realism, clean skin detail without airbrushing\"\n  },\n  \"background\": {\n    \"setting\": \"plain neutral studio wall\",\n    \"wall_color\": \"medium grey, flat and featureless\",\n    \"elements\": [],\n    \"atmosphere\": \"simple, clean, nothing competing with the subject\",\n    \"lighting\": \"soft natural window light from the front and slightly to the left, gentle enough to show facial structure and jawline definition without harsh shadows, a subtle catch light in both eyes to make the green pop, NOT professional studio lighting\"\n  }\n}\n",
              "variableName": "Prompt: ES-2 Portrait (from scratch)",
              "batchMode": false,
              "templateMode": false,
