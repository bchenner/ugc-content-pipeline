            "title": "7. Prompt: ES-2 PiP (white background)",
            "properties": {
              "text": "{\n  \"reference_input\": \"Approved character reference sheet from step 2 (es2-step2-charsheet)\",\n  \"character_reference\": {\n    \"instruction\": \"Use the attached character reference sheet as the absolute ground truth for the subject's facial features, skin texture, and body proportions. The output must be a 1:1 match of the character provided.\",\n    \"face\": {\n      \"preserve_original\": true\n    }\n  },\n  \"subject\": {\n    \"description\": \"A Latino man in his late twenties taking a selfie, phone held in his right hand at arm's length, mid sentence and speaking directly at the camera with confident energy, slight forward lean, left hand relaxed at his side. Muscular build visible through his shirt, broad shoulders, defined arms.\",\n    \"age\": \"late 20s to early 30s\",\n    \"expression\": \"mid sentence, speaking to camera, confident direct eye contact, warm self assured energy\"\n  },\n  \"face\": {\n    \"preserve_original\": true,\n    \"skin\": \"warm medium tan, clear and healthy, clean shaven\"\n  },\n  \"hair\": {\n    \"color\": \"dark brown almost black\",\n    \"style\": \"short on the sides with a clean fade, longer on top and styled with texture, swept slightly to one side\"\n  },\n  \"clothing\": {\n    \"top\": {\n      \"type\": \"fitted dark grey athletic t shirt\",\n      \"color\": \"dark charcoal grey\",\n      \"details\": \"performance fabric stretching across chest and shoulders, crew neck, plain, no logos or prints\"\n    }\n  },\n  \"accessories\": {\n    \"wrist\": {\n      \"type\": \"black fitness tracker\",\n      \"details\": \"worn on left wrist, simple black band, small digital face\"\n    }\n  },\n  \"photography\": {\n    \"camera_style\": \"front facing smartphone selfie at arm's length\",\n    \"angle\": \"slightly above eye level, classic selfie angle\",\n    \"shot_type\": \"upper body, chest and above, vertical composition\",\n    \"aspect_ratio\": \"9:16 vertical\",\n    \"texture\": \"bright even flat lighting, sharp focus, no shadows, social media realism, clean edges for background removal\"\n  },\n  \"background\": {\n    \"setting\": \"pure white background, completely empty\",\n    \"wall_color\": \"pure white, seamless\",\n    \"elements\": [],\n    \"atmosphere\": \"clean isolation for background removal, no objects, no textures, no environment\",\n    \"lighting\": \"bright even lighting from all directions, no cast shadows, no directional light, flat and uniform for clean edge separation\"\n  },\n  \"--no\": \"background objects, environment, shadows, professional lighting rigs, studio equipment, patterns on clothing, jewelry, tattoos, bokeh, 3d render, brown eyes, facial hair, beard, stubble\"\n}\n",
              "variableName": "Prompt: ES-2 PiP (white background)",
