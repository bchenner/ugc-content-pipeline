            "title": "10. Prompt: ES-2 Full Frame (apartment)",
            "properties": {
              "text": "{\n  \"reference_input\": \"Approved character reference sheet from step 2 (es2-step2-charsheet)\",\n  \"character_reference\": {\n    \"instruction\": \"Use the attached character reference sheet as the absolute ground truth for the subject's facial features, skin texture, and body proportions. The output must be a 1:1 match of the character provided.\",\n    \"face\": {\n      \"preserve_original\": true\n    }\n  },\n  \"subject\": {\n    \"description\": \"A Latino man in his late twenties standing in his apartment, mid sentence and speaking to the camera with easy confidence, one hand gesturing at chest height while the other rests on the counter beside him, slight head tilt like he is explaining something. Muscular build visible through his shirt, broad shoulders filling the frame, defined arms stretching the sleeves.\",\n    \"age\": \"late 20s to early 30s\",\n    \"expression\": \"mid sentence, confident warm smile, direct eye contact, slight head tilt, talking to camera with natural charisma\"\n  },\n  \"face\": {\n    \"preserve_original\": true,\n    \"skin\": \"warm medium tan, clear and healthy, clean shaven\"\n  },\n  \"hair\": {\n    \"color\": \"dark brown almost black\",\n    \"style\": \"short on the sides with a clean fade, longer on top and styled with texture, swept slightly to one side\"\n  },\n  \"clothing\": {\n    \"top\": {\n      \"type\": \"fitted dark grey athletic t shirt\",\n      \"color\": \"dark charcoal grey\",\n      \"details\": \"performance fabric stretching across chest and shoulders, crew neck, plain, no logos or prints\"\n    }\n  },\n  \"accessories\": {\n    \"wrist\": {\n      \"type\": \"black fitness tracker\",\n      \"details\": \"worn on left wrist, simple black band, small digital face\"\n    }\n  },\n  \"photography\": {\n    \"camera_style\": \"smartphone propped on a shelf, slightly off center framing\",\n    \"angle\": \"eye level, subject positioned slightly left of center\",\n    \"shot_type\": \"upper body, chest and above, vertical composition\",\n    \"aspect_ratio\": \"9:16 vertical\",\n    \"texture\": \"natural window light, social media realism, sharp but not professional, iPhone video frame quality\"\n  },\n  \"background\": {\n    \"setting\": \"clean modern apartment living space, minimalist but lived in\",\n    \"wall_color\": \"white to light warm grey\",\n    \"elements\": [\n      \"monstera plant in a simple pot near the window\",\n      \"floating wooden shelf with a few supplement bottles and a pair of wireless earbuds\",\n      \"rolled up yoga mat leaning against the wall\",\n      \"shaker bottle sitting on the kitchen counter behind him\"\n    ],\n    \"atmosphere\": \"real apartment belonging to someone who takes fitness seriously, casual and comfortable, not a studio\",\n    \"lighting\": \"natural daylight from a window on the left side, soft and directional, NOT professional lighting, not ring light\"\n  },\n  \"--no\": \"professional lighting, studio setup, gym, tattoos, jewelry, patterns on clothing, bokeh, 3d render, brown eyes, facial hair, beard, stubble\"\n}\n",
